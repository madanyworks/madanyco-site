# Copy this file to .env.local and fill in your values.
# In production, set these in the Vercel dashboard (Settings, Environment Variables).

# Formspree form ID for the /get-started contact form.
# Get one at https://formspree.io; without this, the form falls back to mailto:.
NEXT_PUBLIC_FORMSPREE_ID=

# Klaviyo, for the newsletter signup (/api/subscribe).
# KLAVIYO_API_KEY: a Private API Key from Klaviyo (Settings, API Keys).
# KLAVIYO_LIST_ID: the ID of the list new subscribers join (Lists & Segments).
# Without both, the signup form still confirms to the visitor but writes nowhere.
KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=
